---
import Layout from "../layouts/Layout.astro";
import { Hero } from "../components/Hero";
import { About } from "../components/About";
import { Stats } from "../components/Stats";
import { Reveal } from "../components/Reveal";
import { Accommodations } from "../components/Accommodations";
import { Amenities } from "../components/Amenities";
import { Restaurant } from "../components/Restaurant";
import { Location } from "../components/Location";
import { Reviews } from "../components/Reviews";
import { Booking } from "../components/Booking";
import SocialCards from "../components/ui/card-fan-carousel";

const img = (name: string) => `/images/${name.replace(/\.jpg$/, ".webp")}`;

const galleryCards = [
  { imgUrl: img("h_kleopatra_1720179402_3405434106756331954_3594665146.webp"), alt: "Sunset over the Adriatic from the terrace" },
  { imgUrl: img("h_kleopatra_1690136113_3153412732354361225_3594665146.webp"), alt: "Swimming pool surrounded by greenery" },
  { imgUrl: img("h_kleopatra_1784646699_3946224164977439346_3594665146.webp"), alt: "Hotel Kleopatra exterior with pool view" },
  { imgUrl: img("h_kleopatra_1688587883_3140425240852529702_3594665146.webp"), alt: "Hotel exterior with Mediterranean facade" },
  { imgUrl: img("h_kleopatra_1753613379_3685898640275418367_3594665146.webp"), alt: "Evening terrace with string lights" },
  { imgUrl: img("h_kleopatra_1784541454_3945341474472267267_3594665146.webp"), alt: "Hotel Kleopatra sea view room" },
  { imgUrl: img("h_kleopatra_1690136113_3153412732346071395_3594665146.webp"), alt: "Sunlit room with sea view" },
  { imgUrl: img("h_kleopatra_1688387618_3138745297865615286_3594665146.webp"), alt: "Outdoor pool and sun loungers" },
  { imgUrl: img("h_kleopatra_1690483365_3156325697890199049_3594665146.webp"), alt: "Dining area at the hotel restaurant" },
  { imgUrl: img("h_kleopatra_1720179402_3405434106496183801_3594665146.webp"), alt: "Hotel room with a private balcony" },
  { imgUrl: img("h_kleopatra_1720710768_3409891530259138055_3594665146.webp"), alt: "Cozy hotel room interior" },
  { imgUrl: img("h_kleopatra_1688200431_3137175055263267232_3594665146.webp"), alt: "Mediterranean coastline view" },
];


---

<Layout>
  <main id="main-content">
    <Hero client:load />

    <Reveal client:visible>
      <About />
    </Reveal>

    <Reveal client:visible>
      <Stats />
    </Reveal>

    <Reveal client:visible>
      <Accommodations />
    </Reveal>

    <Reveal client:visible>
      <Amenities />
    </Reveal>

    <section id="gallery" class="bg-cream py-24 md:py-32">
      <div class="container-lux">
        <div class="mx-auto max-w-2xl text-center">
          <span class="eyebrow">Gallery</span>
          <h2 class="mt-4 font-display text-4xl leading-tight text-chocolate md:text-5xl">
            Moments by the <span class="text-gradient-gold italic">Adriatic</span>
          </h2>
          <p class="mt-5 font-manrope text-sm text-chocolate/70 sm:text-base">
            A glimpse of the light, the water and the quiet luxury that awaits.
          </p>
        </div>
      </div>

      <SocialCards cards={galleryCards} client:visible />
    </section>

    <Reveal client:visible>
      <Restaurant />
    </Reveal>

    <Reveal client:visible>
      <Location />
    </Reveal>

    <Reveal client:visible>
      <Reviews />
    </Reveal>

    <Reveal client:visible>
      <Booking />
    </Reveal>

    <div id="booking" />
  </main>
</Layout>
