---
import Layout from "../layouts/Layout.astro";
import { Hero } from "../components/Hero";
import { About } from "../components/About";
import { Stats } from "../components/Stats";
import { Reveal } from "../components/Reveal";
import { Accommodations } from "../components/Accommodations";
import { Amenities } from "../components/Amenities";
import { Restaurant } from "../components/Restaurant";
import { Location } from "../components/Location";
import { Reviews } from "../components/Reviews";
import { Booking } from "../components/Booking";

const img = (name: string) => `/images/${name.replace(/\.jpg$/, ".webp")}`;

const galleryImages = [
  img("h_kleopatra_1720179402_3405434106756331954_3594665146.webp"),
  img("h_kleopatra_1690136113_3153412732354361225_3594665146.webp"),
  img("h_kleopatra_1784646699_3946224164977439346_3594665146.webp"),
  img("h_kleopatra_1688587883_3140425240852529702_3594665146.webp"),
  img("h_kleopatra_1753613379_3685898640275418367_3594665146.webp"),
  img("h_kleopatra_1784541454_3945341474472267267_3594665146.webp"),
];


---

<Layout>
  <main id="main-content">
    <Hero client:load />

    <Reveal client:visible>
      <About />
    </Reveal>

    <Reveal client:visible>
      <Stats />
    </Reveal>

    <Reveal client:visible>
      <Accommodations />
    </Reveal>

    <Reveal client:visible>
      <Amenities />
    </Reveal>

    <section id="gallery" class="relative bg-cream py-24 md:py-32">
      <div class="container-lux">
        <div class="mx-auto max-w-2xl text-center">
          <span class="eyebrow">Gallery</span>
          <h2 class="mt-4 font-display text-4xl leading-tight text-chocolate md:text-5xl">
            Moments by the <span class="text-gradient-gold italic">Adriatic</span>
          </h2>
          <p class="mt-5 font-manrope text-sm text-chocolate/70 sm:text-base">
            A glimpse of the light, the water and the quiet luxury that awaits.
          </p>
        </div>
      </div>

      <div class="mt-12 flex h-[300px] w-full max-w-6xl gap-2 overflow-x-auto px-4 sm:mx-auto sm:px-6 md:h-[400px]">
        {galleryImages.map((src, idx) => (
          <div class="group relative w-14 flex-shrink-0 overflow-hidden rounded-2xl transition-all duration-700 hover:w-full sm:w-20 md:w-24">
            <img
              class="absolute inset-0 h-full w-full object-cover object-center"
              src={src}
              alt={`Hotel Kleopatra gallery image ${idx + 1}`}
              loading={idx < 2 ? "eager" : "lazy"}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-chocolate/40 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
          </div>
        ))}
      </div>
    </section>

    <Reveal client:visible>
      <Restaurant />
    </Reveal>

    <Reveal client:visible>
      <Location />
    </Reveal>

    <Reveal client:visible>
      <Reviews />
    </Reveal>

    <Reveal client:visible>
      <Booking />
    </Reveal>

    <div id="booking" />
  </main>
</Layout>
